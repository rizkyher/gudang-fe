{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gudang-fe",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}